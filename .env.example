# ─── NURE Site Configuration ───
#
# Copy this to .env and fill in values

# Use mock data (true) or live WordPress API (false)
PUBLIC_USE_MOCK=true

# WordPress REST API endpoint
WP_API_URL=https://nure.ua/wp-json/wp/v2

# Webhook secret for WordPress → site rebuild
WP_WEBHOOK_SECRET=change-me-to-random-string

# Vercel Deploy Hook URL (from Vercel Dashboard → Settings → Git → Deploy Hooks)
VERCEL_DEPLOY_HOOK=

# CIST Schedule API
CIST_API_URL=https://cist.nure.ua/ias/app/tt

# Site URL (for sitemap, OG tags)
SITE_URL=https://nure.ua
