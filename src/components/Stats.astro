---
import type { Lang } from '../lib/i18n';
import { t } from '../lib/i18n';

interface Props { lang?: Lang; }
const { lang = 'uk' } = Astro.props;
---

<div class="border-y border-border bg-surface-raised py-8 md:py-10 px-6 lg:px-8">
  <div class="max-w-[1320px] mx-auto grid grid-cols-3 md:grid-cols-5 gap-6 md:gap-8 text-center">
    <div>
      <div class="text-2xl md:text-[2rem] font-extrabold tracking-tight leading-none font-mono">90<span class="text-nure-blue">+</span></div>
      <div class="text-xs text-text-muted mt-1.5">{t('stats.years', lang)}</div>
    </div>
    <div>
      <div class="text-2xl md:text-[2rem] font-extrabold tracking-tight leading-none font-mono">7 000<span class="text-nure-blue">+</span></div>
      <div class="text-xs text-text-muted mt-1.5">{t('stats.students', lang)}</div>
    </div>
    <div>
      <div class="text-2xl md:text-[2rem] font-extrabold tracking-tight leading-none font-mono">40<span class="text-nure-blue">+</span></div>
      <div class="text-xs text-text-muted mt-1.5">{t('stats.programs', lang)}</div>
    </div>
    <div class="hidden md:block">
      <div class="text-2xl md:text-[2rem] font-extrabold tracking-tight leading-none font-mono">30<span class="text-nure-blue">+</span></div>
      <div class="text-xs text-text-muted mt-1.5">{t('stats.partners', lang)}</div>
    </div>
    <div class="hidden md:block">
      <div class="text-2xl md:text-[2rem] font-extrabold tracking-tight leading-none font-mono">6</div>
      <div class="text-xs text-text-muted mt-1.5">{t('stats.faculties', lang)}</div>
    </div>
  </div>
</div>
