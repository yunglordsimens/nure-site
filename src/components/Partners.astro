---
import type { Lang } from '../lib/i18n';
import { t } from '../lib/i18n';
import { getPartnersByTier } from '../lib/api';

interface Props { lang?: Lang; }
const { lang = 'uk' } = Astro.props;

const globalPartners = getPartnersByTier('global');
const regionalPartners = getPartnersByTier('regional');
const intlPartners = getPartnersByTier('international');
---

<section class="py-16 md:py-20 px-6 lg:px-8 fade-in-up">
  <div class="max-w-[1320px] mx-auto">
    <div class="mb-10">
      <div class="font-mono text-[0.65rem] text-nure-blue tracking-[0.15em] uppercase mb-2">{t('partners.label', lang)}</div>
      <h2 class="text-[1.75rem] font-bold tracking-tight">{t('partners.title', lang)}</h2>
    </div>

    <div class="mb-8">
      <div class="font-mono text-[0.6rem] text-text-muted uppercase tracking-[0.15em] text-center mb-6">{t('partners.global', lang)}</div>
      <div class="flex items-center justify-center gap-8 md:gap-12 flex-wrap">
        {globalPartners.map(p => (
          <a href={p.url} target="_blank" rel="noopener noreferrer" class="opacity-40 hover:opacity-100 transition-opacity" title={p.name}>
            <img src={p.logoUrl} alt={p.name} class="h-7 w-auto object-contain" loading="lazy" onerror={`this.outerHTML='<span class="text-text-muted/40 font-bold text-lg tracking-tight">${p.name}</span>'`} />
          </a>
        ))}
      </div>
    </div>

    <div class="mb-8">
      <div class="font-mono text-[0.6rem] text-text-muted uppercase tracking-[0.15em] text-center mb-6">{t('partners.regional', lang)}</div>
      <div class="flex items-center justify-center gap-6 md:gap-10 flex-wrap">
        {regionalPartners.map(p => (
          <a href={p.url} target="_blank" rel="noopener noreferrer" class="opacity-30 hover:opacity-100 transition-opacity" title={p.name}>
            <img src={p.logoUrl} alt={p.name} class="h-5 w-auto object-contain" loading="lazy" onerror={`this.outerHTML='<span class="text-text-muted/30 font-medium text-sm">${p.name}</span>'`} />
          </a>
        ))}
      </div>
    </div>

    <div>
      <div class="font-mono text-[0.6rem] text-text-muted uppercase tracking-[0.15em] text-center mb-6">{t('partners.programs', lang)}</div>
      <div class="flex items-center justify-center gap-8 md:gap-12 flex-wrap">
        {intlPartners.map(p => (
          <a href={p.url} target="_blank" rel="noopener noreferrer" class="opacity-35 hover:opacity-100 transition-opacity" title={p.name}>
            <img src={p.logoUrl} alt={p.name} class="h-6 w-auto object-contain" loading="lazy" onerror={`this.outerHTML='<span class="text-text-muted/35 font-semibold text-base">${p.name}</span>'`} />
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
