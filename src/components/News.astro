---
import type { Lang } from '../lib/i18n';
import { t, getLocalePath } from '../lib/i18n';
import { mockNews, formatDate } from '../lib/api';

interface Props { lang?: Lang; }
const { lang = 'uk' } = Astro.props;

const news = mockNews[lang];
const featured = news.find(n => n.featured) || news[0];
const rest = news.filter(n => n.id !== featured.id).slice(0, 2);

const tagColors: Record<string, { bg: string; text: string }> = {
  rankings: { bg: 'bg-nure-blue/10', text: 'text-nure-blue' },
  science: { bg: 'bg-success/10', text: 'text-success' },
  events: { bg: 'bg-warning/10', text: 'text-warning' },
  university: { bg: 'bg-text-muted/10', text: 'text-text-muted' },
};
---

<section class="py-16 md:py-20 px-6 lg:px-8 fade-in-up">
  <div class="max-w-[1320px] mx-auto">
    <div class="flex items-end justify-between mb-8">
      <div>
        <div class="font-mono text-[0.65rem] text-nure-blue tracking-[0.15em] uppercase mb-2">
          {lang === 'uk' ? 'Останні оновлення' : 'Latest Updates'}
        </div>
        <h2 class="text-[1.75rem] font-bold tracking-tight">{t('news.title', lang)}</h2>
      </div>
      <a href={getLocalePath('/news', lang)} class="hidden sm:flex items-center gap-1 text-nure-blue text-[0.85rem] font-medium hover:gap-2 transition-all no-underline">
        {t('news.all', lang)}
      </a>
    </div>

    <div class="grid md:grid-cols-2 gap-4">
      <a
        href={getLocalePath(`/news/${featured.slug}`, lang)}
        class="row-span-2 relative rounded-2xl p-8 min-h-[380px] md:min-h-[420px] flex flex-col justify-end no-underline overflow-hidden group hover:-translate-y-1 transition-transform duration-300"
      >
        <div class="absolute inset-0 bg-gradient-to-br from-[#0c0c2d] via-[#1a1a3e] to-[#0a1628] z-0"></div>
        <div class="relative z-10">
          <span class:list={["inline-block font-mono text-[0.6rem] tracking-wider uppercase px-2.5 py-1 rounded mb-3", tagColors[featured.tag].bg, tagColors[featured.tag].text]}>
            {featured.tag}
          </span>
          <div class="font-mono text-[0.7rem] text-white/50 mb-2">{formatDate(featured.date, lang)}</div>
          <h3 class="text-white text-xl md:text-2xl font-bold leading-tight mb-3 group-hover:text-nure-blue-light transition-colors">
            {featured.title}
          </h3>
          <p class="text-white/50 text-[0.85rem] leading-relaxed">{featured.excerpt}</p>
        </div>
      </a>

      {rest.map(item => (
        <a
          href={getLocalePath(`/news/${item.slug}`, lang)}
          class="bg-surface-raised border border-border rounded-2xl p-6 no-underline text-text-primary flex flex-col justify-between group hover:border-nure-blue hover:-translate-y-1 hover:shadow-[0_8px_30px_rgba(0,0,0,0.05)] transition-all duration-300"
        >
          <div>
            <span class:list={["inline-block font-mono text-[0.6rem] tracking-wider uppercase px-2.5 py-1 rounded mb-2", tagColors[item.tag].bg, tagColors[item.tag].text]}>
              {item.tag}
            </span>
            <div class="font-mono text-[0.7rem] text-text-muted mb-2">{formatDate(item.date, lang)}</div>
            <h3 class="text-base font-semibold leading-snug">{item.title}</h3>
          </div>
          <div class="text-nure-blue text-[0.8rem] font-medium mt-4 flex items-center gap-1 group-hover:gap-2 transition-all">
            {t('news.readmore', lang)}
          </div>
        </a>
      ))}
    </div>

    <a href={getLocalePath('/news', lang)} class="sm:hidden block text-center text-nure-blue text-sm font-medium mt-6 no-underline">
      {t('news.all', lang)}
    </a>
  </div>
</section>
